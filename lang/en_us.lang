	value.TEXTURE_FILTERING_CPF.0 = none
	value.TEXTURE_FILTERING_CPF.1 = bilinear
	value.TEXTURE_FILTERING_CPF.2 = bilinear (adaptive)
	value.TEXTURE_FILTERING_CPF.3 = crisp-1
	value.TEXTURE_FILTERING_CPF.4 = crisp/blended (ALPHA)
	value.TEXTURE_FILTERING_CPF.5 = crisp-2 (fast)
	value.TEXTURE_FILTERING_CPF.6 = rounded crisp (ALPHA)
	value.TEXTURE_FILTERING_CPF.7 = rounded (ALPHA)
	
